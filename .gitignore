*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

